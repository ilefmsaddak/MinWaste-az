# Copier vers .env à la racine du projet
# Le backend charge : ../.env puis backend/.env (ce dernier écrase)



# Même projet Firebase que l’app Web (ex. minwaste-app)


# Alternative au fichier secrets/firebase.json : décommenter et remplir depuis le JSON Admin SDK
# FIREBASE_CLIENT_EMAIL=""
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

PORT=4000
FRONTEND_URL="http://localhost:4200"

# Optionnel — Azure Blob (photos items)
# AZURE_STORAGE_CONNECTION_STRING=
# CONTAINER_NAME=
# NEXT_PUBLIC_AZURE_STORAGE_BASE_URL=

# Optionnel — Azure OpenAI (route /ai)
# AZURE_OPENAI_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_DEPLOYMENT=
